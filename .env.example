# Copy this file to `.env` and fill real values for production.
# For local testing you can set RECAPTCHA_DISABLED=1 to bypass verification.

# reCAPTCHA keys (register at https://www.google.com/recaptcha/admin)
RECAPTCHA_SITE_KEY=your_site_key_here
RECAPTCHA_SECRET_KEY=your_secret_key_here

# Enable for local dev to bypass reCAPTCHA (set to 1 or true)
RECAPTCHA_DISABLED=0

# Groq API key (or legacy env name `groq_api` is also supported)
GROQ_API_KEY=your_groq_api_key_here
# groq_api=legacy_key_value
